# portal/frontend/Dockerfile
# Build context: minimal staging dir (see azure-deploy.sh Step 9)
# Expected layout in build context: Dockerfile, package*.json, src/, public/, *.json, *.ts, *.mjs

# ── Stage 1: Build ────────────────────────────────────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app

# Install dependencies (separate layer for better caching)
COPY portal/frontend/package*.json ./
RUN npm ci

# Copy source and build
COPY portal/frontend/ .

# NEXT_PUBLIC_API_URL is baked into the client bundle at build time.
# Pass the real backend URL with --build-arg when building for production.
# Default works for local docker-compose testing.
ARG NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

RUN npm run build

# ── Stage 2: Production runner ────────────────────────────────────────────────
FROM node:20-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production

# Standalone output: server.js + required node_modules, no full node_modules copy
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static     ./.next/static
COPY --from=builder /app/public           ./public

EXPOSE 3000

# server.js is generated by Next.js standalone build
CMD ["node", "server.js"]
