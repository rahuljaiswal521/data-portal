# portal/backend/.env.example
# Copy to .env and fill in your values.
# Never commit the real .env to git.

# ── Databricks ────────────────────────────────────────────────────────────────
DATABRICKS_HOST=https://adb-XXXXXXXXXXXX.X.azuredatabricks.net
DATABRICKS_TOKEN=dapi...
DATABRICKS_WAREHOUSE_ID=...
DATABRICKS_CLUSTER_ID=...

# Optional Databricks paths (defaults shown)
# DATABRICKS_WORKSPACE_PATH=/Workspace/bronze_framework
# DATABRICKS_SILVER_WORKSPACE_PATH=/Workspace/silver_framework

# ── AI / RAG ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional RAG tuning (defaults shown)
# RAG_MODEL=claude-sonnet-4-5-20250929
# RAG_MAX_TOKENS=1024
# RAG_TEMPERATURE=0.3

# ── Paths (only needed for local dev outside Docker) ─────────────────────────
# In Docker these are set via ENV in the Dockerfile and should NOT be set here.
# FRAMEWORK_ROOT=C:/Users/you/Demo/bronze_framework
# SILVER_FRAMEWORK_ROOT=C:/Users/you/Demo/silver_framework

# ── Git ───────────────────────────────────────────────────────────────────────
GIT_ENABLED=true      # Set to false in Docker / Azure
GIT_AUTO_PUSH=false

# ── CORS ─────────────────────────────────────────────────────────────────────
# Add your Azure Container Apps frontend URL here when deploying.
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ── Misc ─────────────────────────────────────────────────────────────────────
DEFAULT_ENVIRONMENT=dev
